class Solution {
    public int countEven(int num) {
        int temp = num;
        int sum =0;
        int count =0;
        for(int i =2 ; i<= temp ; i++){
          int n =i;
            while(n != 0){
                int rem = n %10;
                 sum = sum + rem;
                n = n /10;
                
              
            }
            if( sum % 2 == 0) count++;
            else sum=0;
        }
        return count;
    }
}
