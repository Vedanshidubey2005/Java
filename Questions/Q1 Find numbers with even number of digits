class Solution {
    public int findNumbers(int[] nums) {
        int count =0;

   for(int i=0;i< nums.length;i++){
    if(even(nums[i])){
        count++;
    }
   }

   return count;
    }
    boolean even(int i){
        int c=0;
        while(i!=0){
            i=i/10;
  c++;
        }
        if(c%2==0) return true;
        return false;
    }
}
