class Solution {
    public int mostWordsFound(String[] sentences) {
        int maxx =0;
        for(int i =0 ;i < sentences.length;i++){
            int currL = wordsc(sentences[i]);
            if(currL > maxx){
                maxx= currL;
            }
        }
        return maxx;
    }
    int wordsc(String str){
        int cnt = 0;
        for(int i =0;i< str.length(); i++){
            if(str.charAt(i) ==' '){
                cnt++;
            }
        }
        return cnt+1;
    }
}
