class Solution {
    public int xorOperation(int n, int start) {
        int[] arr= new int[n];
        int xor=0;
        for(int i =0; i<= n-1;i++){
           arr[i]= start + 2 * i;
        xor = xor ^ arr[i];
        }
        //  for(int i =0; i<= n-1;i++){
        // xor = xor ^ arr[i];
        //  }
        return xor;
    }
}
